<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="#0E1120"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/app_logo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_volume_outline"

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VolTile Control Center"
            android:textColor="#EEEEFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ringer_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ringer: Sound On"
            android:textColor="#8890BB"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Quick Ringer Toggle button in notification -->
    <ImageButton
        android:id="@+id/btn_quick_ringer"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_ring"
        android:contentDescription="Toggle Ringer" />

    <!-- Quick Media Mute toggle -->
    <ImageButton
        android:id="@+id/btn_quick_media_mute"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_music"
        android:layout_marginEnd="8dp"
        android:contentDescription="Mute Media" />

</LinearLayout>

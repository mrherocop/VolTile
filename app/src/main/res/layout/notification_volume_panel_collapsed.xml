<?xml version="1.0" encoding="utf-8"?>
<!-- SONIQ Collapsed Notification — lime background, SONIQ branding, quick toggle buttons -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="#D4FF00"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_volume_outline"
        android:tint="#000000"
        android:contentDescription="SONIQ icon"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SONIQ"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.03"/>

        <TextView
            android:id="@+id/ringer_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sound On"
            android:textColor="#333333"
            android:textSize="11sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Quick ringer toggle -->
    <ImageButton
        android:id="@+id/btn_quick_ringer"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="#00000000"
        android:src="@drawable/ic_ring_vol"
        android:tint="#000000"
        android:contentDescription="Toggle Ringer"/>

    <!-- Quick media mute toggle -->
    <ImageButton
        android:id="@+id/btn_quick_media_mute"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="#00000000"
        android:src="@drawable/ic_music_note"
        android:tint="#000000"
        android:layout_marginStart="4dp"
        android:contentDescription="Mute Media"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="256dp"
    android:background="#0E1120"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Top Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:id="@+id/expanded_logo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_volume_outline"
            android:tint="#5B7BFF"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VolTile Volume Panel"
            android:textColor="#EEEEFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_toEndOf="@id/expanded_logo"
            android:layout_marginStart="8dp"
            android:layout_centerVertical="true" />

        <!-- Quick Launch App button -->
        <TextView
            android:id="@+id/btn_open_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPEN APP"
            android:textColor="#5B7BFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:padding="6dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent" />
    </RelativeLayout>

    <!-- Ringer Modes Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/btn_ringer_sound"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:gravity="center"
            android:text="🔊 Sound"
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:background="#141830" />

        <TextView
            android:id="@+id/btn_ringer_vibrate"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:gravity="center"
            android:text="📳 Vibrate"
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:background="#141830" />

        <TextView
            android:id="@+id/btn_ringer_silent"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:gravity="center"
            android:text="🔇 Silent"
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:background="#141830" />
    </LinearLayout>

    <!-- Media Stream Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_music"
            android:tint="#5B7BFF"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="Media"
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:layout_marginStart="6dp" />

        <ImageButton
            android:id="@+id/btn_media_down"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_minus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <ProgressBar
            android:id="@+id/progress_media"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="#5B7BFF"
            android:progressBackgroundTint="#1E2240" />

        <ImageButton
            android:id="@+id/btn_media_up"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_plus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <TextView
            android:id="@+id/txt_media_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#5B7BFF"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <!-- Ring Stream Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_ring"
            android:tint="#BB6BFF"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="Ring"
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:layout_marginStart="6dp" />

        <ImageButton
            android:id="@+id/btn_ring_down"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_minus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <ProgressBar
            android:id="@+id/progress_ring"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="#BB6BFF"
            android:progressBackgroundTint="#1E2240" />

        <ImageButton
            android:id="@+id/btn_ring_up"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_plus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <TextView
            android:id="@+id/txt_ring_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#BB6BFF"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <!-- Alarm Stream Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_alarm"
            android:tint="#FF8C42"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="Alarm"
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:layout_marginStart="6dp" />

        <ImageButton
            android:id="@+id/btn_alarm_down"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_minus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <ProgressBar
            android:id="@+id/progress_alarm"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="#FF8C42"
            android:progressBackgroundTint="#1E2240" />

        <ImageButton
            android:id="@+id/btn_alarm_up"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_plus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <TextView
            android:id="@+id/txt_alarm_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#FF8C42"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <!-- Notification Stream Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_notification"
            android:tint="#FFD166"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="Notif."
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:layout_marginStart="6dp" />

        <ImageButton
            android:id="@+id/btn_notification_down"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_minus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <ProgressBar
            android:id="@+id/progress_notification"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="#FFD166"
            android:progressBackgroundTint="#1E2240" />

        <ImageButton
            android:id="@+id/btn_notification_up"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_plus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <TextView
            android:id="@+id/txt_notification_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#FFD166"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <!-- Call Stream Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_call"
            android:tint="#3DD68C"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="Call"
            android:textColor="#8890BB"
            android:textSize="11sp"
            android:layout_marginStart="6dp" />

        <ImageButton
            android:id="@+id/btn_call_down"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_minus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <ProgressBar
            android:id="@+id/progress_call"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="#3DD68C"
            android:progressBackgroundTint="#1E2240" />

        <ImageButton
            android:id="@+id/btn_call_up"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_plus"
            android:tint="#8890BB"
            android:padding="6dp" />

        <TextView
            android:id="@+id/txt_call_val"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#3DD68C"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!-- SONIQ Expanded Notification Panel — matches soniq_notification_bar.html exactly -->
<!-- Background: #D4FF00, white header, 3 ringer mode buttons, 4 volume sliders in white card -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#D4FF00"
    android:padding="0dp">

    <!-- ══ HEADER ══════════════════════════════════════════════════ -->
    <!-- White bar: volume icon + "SONIQ" bold + "OPEN APP" link -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <!-- Left: icon + SONIQ label -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_volume_outline"
                android:tint="#000000"
                android:contentDescription="Volume icon"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="SONIQ"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:fontFamily="sans-serif-black"/>
        </LinearLayout>

        <!-- Right: "OPEN APP" text button -->
        <TextView
            android:id="@+id/btn_open_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPEN APP"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:fontFamily="monospace"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Bottom border of header: 4dp black line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="#000000"/>

    <!-- ══ RINGER MODE BUTTONS ═══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#D4FF00"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:weightSum="3">

        <!-- SOUND button (active = green card) -->
        <LinearLayout
            android:id="@+id/btn_mode_sound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#22C55E"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_volume_outline"
                android:tint="#000000"
                android:contentDescription="Sound mode"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="SOUND"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- VIBRATE button (inactive = white) -->
        <LinearLayout
            android:id="@+id/btn_mode_vibrate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#FFFFFF"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_vibrate"
                android:tint="#000000"
                android:contentDescription="Vibrate mode"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="VIBRATE"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- SILENT button (inactive = white) -->
        <LinearLayout
            android:id="@+id/btn_mode_silent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#FFFFFF"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_bell_off"
                android:tint="#000000"
                android:contentDescription="Silent mode"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="SILENT"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom border of ringer section -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="#000000"/>

    <!-- ══ VOLUME SLIDERS (White panel) ═══════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Media row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_music_note"
                android:tint="#000000"
                android:background="#D4FF00"
                android:padding="4dp"
                android:contentDescription="Media volume"/>

            <SeekBar
                android:id="@+id/seek_media"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:max="15"
                android:progress="12"
                android:progressTint="#22C55E"
                android:thumbTint="#000000"/>

            <TextView
                android:id="@+id/tv_media_pct"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="80%"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Ring row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_ring_vol"
                android:tint="#000000"
                android:background="#D4FF00"
                android:padding="4dp"
                android:contentDescription="Ring volume"/>

            <SeekBar
                android:id="@+id/seek_ring"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:max="7"
                android:progress="4"
                android:progressTint="#005AC2"
                android:thumbTint="#000000"/>

            <TextView
                android:id="@+id/tv_ring_pct"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="60%"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Alarm row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_alarm_clock"
                android:tint="#000000"
                android:background="#D4FF00"
                android:padding="4dp"
                android:contentDescription="Alarm volume"/>

            <SeekBar
                android:id="@+id/seek_alarm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:max="7"
                android:progress="6"
                android:progressTint="#FD761A"
                android:thumbTint="#000000"/>

            <TextView
                android:id="@+id/tv_alarm_pct"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="90%"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Call row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_phone"
                android:tint="#000000"
                android:background="#D4FF00"
                android:padding="4dp"
                android:contentDescription="Call volume"/>

            <SeekBar
                android:id="@+id/seek_call"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:max="5"
                android:progress="2"
                android:progressTint="#82ABFF"
                android:thumbTint="#000000"/>

            <TextView
                android:id="@+id/tv_call_pct"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
